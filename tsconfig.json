{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "moduleResolution": "bundler",
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "src",
    "vitest.config.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
