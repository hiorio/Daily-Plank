{
  "name": "daily-plank",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:mobile": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web --output-dir dist && node scripts/prepare-pages.js",
    "check": "npm run typecheck && npm run lint && npm test",
    "doctor": "npx expo-doctor",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:simulator:ios": "eas build --profile ios-simulator --platform ios",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:production:ios": "eas build --profile production --platform ios",
    "submit:ios": "eas submit --platform ios",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "56.0.12",
    "expo-asset": "56.0.17",
    "expo-audio": "56.0.12",
    "expo-constants": "56.0.18",
    "expo-haptics": "56.0.3",
    "expo-keep-awake": "56.0.3",
    "expo-linking": "56.0.14",
    "expo-router": "56.2.11",
    "expo-speech": "56.0.3",
    "expo-splash-screen": "56.0.10",
    "expo-sqlite": "56.0.5",
    "lottie-react-native": "7.3.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@expo/ngrok": "4.1.0",
    "@testing-library/react-native": "14.0.0",
    "@types/react": "19.2.17",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "eslint-config-expo": "56.0.4",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
