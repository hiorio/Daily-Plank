{
  "expo": {
    "name": "Daily Plank",
    "slug": "daily-plank",
    "scheme": "dailyplank",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./src/assets/branding/icon.png",
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/branding/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#F5F8F4"
        }
      ],
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-sqlite"
    ],
    "ios": {
      "bundleIdentifier": "com.hiorio.dailyplank",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ko",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hiorio.dailyplank",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/branding/adaptive-icon.png",
        "backgroundColor": "#2A8B59"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/Daily-Plank"
    }
  }
}
