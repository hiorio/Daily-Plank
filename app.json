{
  "expo": {
    "name": "매일 플랭크",
    "slug": "daily-plank",
    "scheme": "dailyplank",
    "version": "0.1.2",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./src/assets/branding/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/branding/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#F5F8F4"
        }
      ],
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-sqlite",
      "expo-asset",
      "expo-notifications"
    ],
    "ios": {
      "bundleIdentifier": "com.hiorio.dailyplank",
      "buildNumber": "12",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleDisplayName": "매일 플랭크",
        "CFBundleDevelopmentRegion": "ko",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hiorio.dailyplank",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/branding/adaptive-icon.png",
        "backgroundColor": "#1E86E0"
      },
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/branding/icon.png"
    },
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/Daily-Plank"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2b9a08a4-d627-4722-844f-68ae70c10275"
      }
    },
    "owner": "hiorio"
  }
}
